# ============================================================
#  RTX 5090 部署版 (31b / 32 GB 显存) — 含部署元数据 banner
#  自动生成自 gemma4-31b-uncensored.Modelfile  请勿手工编辑 (改动应改原 Modelfile 后用同流程重生成)
#  原 Modelfile = 同份 RTX 5090 配置 (无 banner), 本文件 = 原 + 部署 banner
# ============================================================
#
#  【部署前置条件】ollama daemon 必须以以下 env vars 启动, 否则下方显存预算/性能数据不成立:
#      OLLAMA_FLASH_ATTENTION=1      # FA: 加速 prefill + 降低 KV 内存
#      OLLAMA_KV_CACHE_TYPE=q8_0     # KV cache 8bit 量化, 占用减半, 质量损失可忽略
#  推荐启动方式: bash /root/autodl-tmp/ollama/start_ollama.sh (该脚本已 baked 这两个 env)
#  验证 env 已生效: tr '\0' '\n' < /proc/$(pgrep -f 'ollama serve')/environ | grep ^OLLAMA_
#
#  【显存预算 (5090 共 32.6 GB)】
#      31b: weights ~19 GB + KV(q8_0)@32768 ~5 GB + scratch ~2 GB ≈ ~24 GB (剩余 ~8 GB)
#      不开 q8_0 时 31b@32K 会 OOM (KV FP16 ~10 GB, 总占 ~32 GB 没余地); q8_0 是 31b 推到 32K 的硬性前提
#
#  【参数选择依据】
#    num_ctx 32768  : 5090 显存上限+q8_0 KV 综合权衡, 26b/31b 统一 32K
#    num_gpu 999     : 全层 offload; ollama 看到 999 自动夹到模型实际层数
#    num_batch 1024 : ★ 实测 batch=2048 prefill 暴跌 5× (3296->699 tok/s), 31b 单层张量大超 5090 L2 cache (96 MB)
#    num_thread 6    : 全 GPU offload 时基本无影响, 保留默认
#    其余 SYSTEM/采样/stop : 与原 Modelfile 完全一致, 本调优只动性能相关参数
#
#  【实测性能基线 (2026-04-23, system prompt ~12K tokens)】
#      31b @ ctx=32768 batch=1024 + FA+q8_0 : VRAM 24.0 GB, prefill 3151 tok/s, eval 56 tok/s ★ q8_0 让 ctx 翻 1.33× 而几乎不损速
#      31b @ ctx=24576 batch=1024 + 无 q8_0  : VRAM 26.1 GB, prefill 3296 tok/s, eval 58 tok/s (旧基线)
#
#  【部署】
#      scp -P <SERVER_PORT> gemma4-31b-uncensored.5090.Modelfile root@<SERVER_HOST>:/root/autodl-tmp/modelfiles/
#      ssh -p <SERVER_PORT> root@<SERVER_HOST> '
#        export PATH="/root/autodl-tmp/ollama/bin:$PATH"
#        export OLLAMA_MODELS="/root/autodl-tmp/ollama/models"
#        ollama create gemma4-31b-uncensored -f /root/autodl-tmp/modelfiles/gemma4-31b-uncensored.5090.Modelfile
#      '
# ============================================================

FROM gemma4:31b

# ---------- 显存/算力 (RTX 5090, 32 GB VRAM) ----------
# 上下文窗口: 5090 + KV(q8_0) 量化, 32K 完全放得下 (KV ~5 GB)
# ★ 不开 OLLAMA_KV_CACHE_TYPE=q8_0 时, 31b@32K 会 OOM (KV FP16 翻倍到 ~10 GB)
PARAMETER num_ctx 32768

# offload 到 GPU 的层数 (gemma4-31b 共 ~63 层)
# 999 = 全层 offload, ollama 自动夹到模型实际层数上限
PARAMETER num_gpu 999

# CPU 线程数: 全 GPU offload 时几乎无影响, 保留 6
PARAMETER num_thread 6

# prompt 处理批大小
# 31b: 1024 (★ 实测 batch=2048 prefill 暴跌 5×, 31b 单层张量大超 5090 L2 cache 96 MB)
PARAMETER num_batch 1024

# ---------- 生成参数 ----------
# 温度略微提高,能降低复读式"安全模板"出现的概率
PARAMETER temperature     0.8
PARAMETER top_p           0.95
PARAMETER top_k           60
PARAMETER min_p           0.05
PARAMETER repeat_penalty  1.1
PARAMETER num_predict     -1

